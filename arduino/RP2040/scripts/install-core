  cd ~/.arduino15
  patch -N -p0 -r - <<EOD
--- packages/arduino/hardware/mbed_rp2040/4.5.0/platform.txt.orig
+++ packages/arduino/hardware/mbed_rp2040/4.5.0/platform.txt
@@ -183,7 +183,7 @@
