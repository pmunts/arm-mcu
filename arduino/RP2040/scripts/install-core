-tools.picotool.upload.pattern="{path}/{cmd}" {upload.verbose} -D "{build.path}/{build.project_name}.elf"
+tools.picotool.upload.pattern=flashpico "{build.path}/{build.project_name}.uf2"

 #
 # IMGTOOL

EOD
fi
