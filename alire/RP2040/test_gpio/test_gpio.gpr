with "config/test_gpio_config.gpr";
with "pico_bsp.gpr";

project test_gpio is

   for Target use "arm-eabi";
   for Runtime ("Ada") use "light-cortex-m0p";
   for Source_Dirs use ("src/", "config/");
   for Object_Dir use "obj/" & test_gpio_Config.Build_Profile;
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "bin";
   for Main use ("test_gpio.adb");

   package Compiler is
      for Default_Switches ("Ada") use test_gpio_Config.Ada_Compiler_Switches & ("-gnaty-g");
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es"); --  Symbolic traceback
   end Binder;

   package Linker is
      for Switches ("Ada") use Pico_BSP.Linker_Switches;
   end Linker;

end test_gpio;
