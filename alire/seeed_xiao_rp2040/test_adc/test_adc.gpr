with "config/test_adc_config.gpr";
with "runtime_build.gpr";

project test_adc is

   for Target use runtime_build'Target;
   for Runtime ("Ada") use runtime_build'Runtime ("Ada");
   for Source_Dirs use ("src/", "config/");
   for Object_Dir use "obj/" & test_adc_Config.Build_Profile;
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "bin";
   for Main use ("test_adc.adb");

   package Compiler is
      for Default_Switches ("Ada") use test_adc_Config.Ada_Compiler_Switches & ("-gnat2022", "-gnaty-g");
   end Compiler;

   package Linker is
      for Switches ("Ada") use Runtime_Build.Linker_Switches & ("-Wl,--gc-sections");
   end Linker;

end test_adc;
