PROGRAM test_leds;

VAR
  LD1 : sbit AT GPIOA_ODR.B1;
  LD2 : sbit AT GPIOA_ODR.B2;

BEGIN

  { Configure LED outputs }

  GPIO_Digital_Output(@GPIOA_BASE, _GPIO_PINMASK_1);
  GPIO_Digital_Output(@GPIOA_BASE, _GPIO_PINMASK_2);

  { Initialize LED outputs }

  LD1 := True;
  LD2 := False;

  { Toggle LED outputs }

  WHILE True DO
    BEGIN
      LD1 := NOT LD1;
      LD2 := NOT LD2;

      Delay_ms(500);
    END
END.
