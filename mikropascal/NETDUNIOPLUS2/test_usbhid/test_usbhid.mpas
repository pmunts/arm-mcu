PROGRAM test_usbhid;

VAR
  LED      : sbit AT GPIOA_ODR.B10;
  readbuf  : string[HID_OUTPUT_REPORT_BYTES];
  writebuf : string[HID_INPUT_REPORT_BYTES];

  PROCEDURE USBInterrupt(); IV IVT_INT_OTG_FS;

  BEGIN
    USB_Interrupt_Proc();
  END;

BEGIN

  { Initialize USB HID library }

  HID_Enable(@readbuf, @writebuf);

  { Enable USB interrupt }

  NVIC_IntEnable(IVT_INT_OTG_FS);

  { Configure LED outputs }

  GPIO_Digital_Output(@GPIOA_BASE, _GPIO_PINMASK_10);

  { Initialize LED outputs }

  LED := False;

  { Event loop }

  WHILE True DO
    BEGIN

      { Check for message from host }

      IF (HID_Read() <> 0) THEN
        BEGIN
          IF strncmp(readbuf, 'LEDON', 5) = 0 THEN
            LED := True;

          IF strncmp(readbuf, 'LEDOFF', 6) = 0 THEN
            LED := False;
        END
    END
END.
